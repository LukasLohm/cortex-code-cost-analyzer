# Cortex Thread Cost Analyzer - Local Development Secrets
# 
# Copy this file to secrets.toml and fill in your credentials:
#   cp secrets.toml.example secrets.toml
#
# NEVER commit secrets.toml to version control!
#
# Get your connection values by running: snow connection list

[connections.snowflake]
account = "YOUR_ORG-YOUR_ACCOUNT"      # e.g., "MYORG-MYACCOUNT" 
user = "YOUR_USERNAME"                  # Your Snowflake username
authenticator = "externalbrowser"       # SSO login (or use "snowflake" + password)
warehouse = "COMPUTE_WH"                # Your warehouse
database = "AGENT_COST_ANALYSIS"        # Or any database you have access to
schema = "APP"                          # Or any schema
# password = "YOUR_PASSWORD"            # Only needed if not using externalbrowser
# host = "your_account.snowflakecomputing.com"  # Include if using private link
